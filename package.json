{
  "name": "pi-web-providers",
  "version": "3.5.1",
  "description": "Configurable web access extension for pi with per-tool provider routing and explicit provider option schemas for search, contents, quick grounded answers, and research.",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "example-config.json",
    "examples"
  ],
  "keywords": [
    "pi-package",
    "pi-extension",
    "coding-agent",
    "web-search",
    "web-contents",
    "web-answer",
    "web-research",
    "provider-routing",
    "brave",
    "claude",
    "cloudflare",
    "codex",
    "custom",
    "exa",
    "firecrawl",
    "gemini",
    "linkup",
    "ollama",
    "openai",
    "parallel",
    "perplexity",
    "serper",
    "tavily",
    "valyu"
  ],
  "author": "mavam",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mavam/pi-web-providers.git"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "rm -rf dist && esbuild src/index.ts --bundle --format=esm --platform=node --outfile=dist/index.js --external:@earendil-works/pi-coding-agent --external:@earendil-works/pi-ai --external:@earendil-works/pi-tui --external:typebox --external:@anthropic-ai/claude-agent-sdk --external:@google/genai --external:@mendable/firecrawl-js --external:@openai/codex-sdk --external:@perplexity-ai/perplexity_ai --external:@tavily/core --external:cloudflare --external:exa-js --external:linkup-sdk --external:openai --external:parallel-web --external:valyu-js",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "check": "tsc --noEmit",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "smoke:live": "npm run build && node scripts/live-smoke.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.215",
    "@google/genai": "^2.12.0",
    "@mendable/firecrawl-js": "^4.30.1",
    "@openai/codex-sdk": "^0.144.6",
    "@perplexity-ai/perplexity_ai": "^0.37.0",
    "@tavily/core": "^0.7.6",
    "cloudflare": "^7.0.0",
    "exa-js": "^2.16.0",
    "linkup-sdk": "^3.2.8",
    "openai": "^6.48.0",
    "parallel-web": "^1.1.0",
    "valyu-js": "^2.9.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@earendil-works/pi-ai": "^0.80.10",
    "@earendil-works/pi-coding-agent": "^0.80.10",
    "@earendil-works/pi-tui": "^0.80.10",
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "typebox": "^1.3.6",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  }
}
