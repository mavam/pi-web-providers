{
  "name": "pi-web-providers",
  "version": "3.5.0",
  "description": "Configurable web access extension for pi with per-tool provider routing and explicit provider option schemas for search, contents, quick grounded answers, and research.",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "example-config.json",
    "examples"
  ],
  "keywords": [
    "pi-package",
    "pi-extension",
    "coding-agent",
    "web-search",
    "web-contents",
    "web-answer",
    "web-research",
    "provider-routing",
    "brave",
    "claude",
    "cloudflare",
    "codex",
    "custom",
    "exa",
    "firecrawl",
    "gemini",
    "linkup",
    "ollama",
    "openai",
    "parallel",
    "perplexity",
    "serper",
    "tavily",
    "valyu"
  ],
  "author": "mavam",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mavam/pi-web-providers.git"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "rm -rf dist && esbuild src/index.ts --bundle --format=esm --platform=node --outfile=dist/index.js --external:@earendil-works/pi-coding-agent --external:@earendil-works/pi-ai --external:@earendil-works/pi-tui --external:typebox --external:@anthropic-ai/claude-agent-sdk --external:@google/genai --external:@mendable/firecrawl-js --external:@openai/codex-sdk --external:@perplexity-ai/perplexity_ai --external:@tavily/core --external:cloudflare --external:exa-js --external:linkup-sdk --external:openai --external:parallel-web --external:valyu-js",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "check": "tsc --noEmit",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "smoke:live": "npm run build && node scripts/live-smoke.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.185",
    "@google/genai": "^2.9.0",
    "@mendable/firecrawl-js": "^4.28.2",
    "@openai/codex-sdk": "^0.141.0",
    "@perplexity-ai/perplexity_ai": "^0.33.0",
    "@tavily/core": "^0.7.6",
    "cloudflare": "^6.4.0",
    "exa-js": "^2.14.0",
    "linkup-sdk": "^3.2.5",
    "openai": "^6.44.0",
    "parallel-web": "^1.1.0",
    "valyu-js": "^2.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@earendil-works/pi-ai": "^0.79.2",
    "@earendil-works/pi-coding-agent": "^0.79.2",
    "@earendil-works/pi-tui": "^0.79.2",
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "typebox": "^1.2.9",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  }
}
